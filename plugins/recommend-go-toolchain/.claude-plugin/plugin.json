{
	"$schema": "../../example-plugin/.claude-plugin/plugin.schema.json",
	"name": "recommend-go-toolchain",
	"description": "Blocks direct go build/test commands - use go-toolchain instead",
	"author": {
		"name": "mhaynie"
	},
	"keywords": ["go", "build", "test", "toolchain", "hook"],
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/build/recommend-go-toolchain"
					}
				]
			}
		]
	},
	"mh": {
		"include_in_marketplace": true
	}
}
