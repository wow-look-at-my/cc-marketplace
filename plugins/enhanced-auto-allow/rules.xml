<?xml version="1.0" encoding="UTF-8"?>
<rules>
  <!-- Readonly inspection commands -->
  <cmd name="ls" allowedFlags="*"/>
  <cmd name="cat" allowedFlags="*"/>
  <cmd name="head" allowedFlags="*"/>
  <cmd name="tail" allowedFlags="*"/>
  <cmd name="file" allowedFlags="*"/>
  <cmd name="wc" allowedFlags="*"/>
  <cmd name="stat" allowedFlags="*"/>
  <cmd name="du" allowedFlags="*"/>
  <cmd name="df" allowedFlags="*"/>
  <cmd name="uname" allowedFlags="*"/>
  <cmd name="uptime" allowedFlags="*"/>
  <cmd name="sw_vers" allowedFlags="*"/>
  <cmd name="arch" allowedFlags="*"/>
  <cmd name="hostinfo" allowedFlags="*"/>
  <cmd name="vm_stat" allowedFlags="*"/>
  <cmd name="whoami" allowedFlags="*"/>
  <cmd name="id" allowedFlags="*"/>
  <cmd name="groups" allowedFlags="*"/>
  <cmd name="pgrep" allowedFlags="*"/>
  <cmd name="which" allowedFlags="*"/>
  <cmd name="whereis" allowedFlags="*"/>
  <cmd name="readlink" allowedFlags="*"/>
  <cmd name="basename" allowedFlags="*"/>
  <cmd name="dirname" allowedFlags="*"/>
  <cmd name="printenv" allowedFlags="*"/>
  <cmd name="shasum" allowedFlags="*"/>
  <cmd name="md5" allowedFlags="*"/>
  <cmd name="strings" allowedFlags="*"/>
  <cmd name="hexdump" allowedFlags="*"/>
  <cmd name="od" allowedFlags="*"/>
  <cmd name="mdfind" allowedFlags="*"/>
  <cmd name="mdls" allowedFlags="*"/>
  <cmd name="locate" allowedFlags="*"/>
  <cmd name="echo" allowedFlags="*"/>
  <cmd name="printf" allowedFlags="*"/>
  <cmd name="true" allowedFlags="*"/>
  <cmd name="false" allowedFlags="*"/>
  <cmd name="test" allowedFlags="*"/>
  <cmd name="[" allowedFlags="*"/>
  <cmd name="date" allowedFlags="*"/>
  <cmd name="hostname" allowedFlags="*"/>
  <cmd name="pwd" allowedFlags="*"/>
  <cmd name="env" allowedFlags="*"/>
  <cmd name="sort" allowedFlags="*"/>
  <cmd name="uniq" allowedFlags="*"/>
  <cmd name="tr" allowedFlags="*"/>
  <cmd name="cut" allowedFlags="*"/>
  <cmd name="diff" allowedFlags="*"/>
  <cmd name="comm" allowedFlags="*"/>
  <cmd name="join" allowedFlags="*"/>
  <cmd name="paste" allowedFlags="*"/>
  <cmd name="column" allowedFlags="*"/>
  <cmd name="expand" allowedFlags="*"/>
  <cmd name="unexpand" allowedFlags="*"/>
  <cmd name="fold" allowedFlags="*"/>
  <cmd name="fmt" allowedFlags="*"/>
  <cmd name="nl" allowedFlags="*"/>
  <cmd name="rev" allowedFlags="*"/>
  <cmd name="tac" allowedFlags="*"/>
  <cmd name="seq" allowedFlags="*"/>
  <cmd name="realpath" allowedFlags="*"/>
  <cmd name="cd" allowedFlags="*"/>
  <cmd name="pkg-config" allowedFlags="*"/>
  <cmd name="pkgconf" allowedFlags="*"/>
  <cmd name="pkg_config" allowedFlags="*"/>

  <!-- find -->
  <cmd name="find" allowedFlags="*">
    <deniedFlags>
      <flag>-delete</flag>
    </deniedFlags>
    <execFlags>
      <flag>-exec</flag>
      <flag>-execdir</flag>
      <flag>-ok</flag>
      <flag>-okdir</flag>
    </execFlags>
  </cmd>

  <!-- grep -->
  <cmd name="grep" allowedFlags="*"/>

  <!-- ldconfig -->
  <cmd name="ldconfig">
    <requiredFlags>
      <flag>-p</flag>
      <flag>--print-cache</flag>
      <flag>-v</flag>
    </requiredFlags>
  </cmd>

  <!-- go -->
  <cmd name="go">
    <subcmd name="version" allowedFlags="*"/>
    <subcmd name="env" allowedFlags="*"/>
    <subcmd name="doc" allowedFlags="*"/>
  </cmd>

  <!-- git -->
  <cmd name="git">
    <subcmd name="status" allowedFlags="*"/>
    <subcmd name="diff" allowedFlags="*"/>
    <subcmd name="log" allowedFlags="*"/>
    <subcmd name="show" allowedFlags="*"/>
    <subcmd name="fetch" allowedFlags="*"/>
    <subcmd name="ls-files" allowedFlags="*"/>
    <subcmd name="ls-tree" allowedFlags="*"/>
    <subcmd name="ls-remote" allowedFlags="*"/>
    <subcmd name="rev-parse" allowedFlags="*"/>
    <subcmd name="rev-list" allowedFlags="*"/>
    <subcmd name="describe" allowedFlags="*"/>
    <subcmd name="blame" allowedFlags="*"/>
    <subcmd name="shortlog" allowedFlags="*"/>
    <subcmd name="whatchanged" allowedFlags="*"/>
    <subcmd name="reflog" allowedFlags="*"/>
    <subcmd name="count-objects" allowedFlags="*"/>
    <subcmd name="fsck" allowedFlags="*"/>
    <subcmd name="verify-pack" allowedFlags="*"/>
    <subcmd name="cat-file" allowedFlags="*"/>
    <subcmd name="for-each-ref" allowedFlags="*"/>
    <subcmd name="name-rev" allowedFlags="*"/>
    <subcmd name="merge-base" allowedFlags="*"/>
    <subcmd name="branch">
      <allowedFlags>
        <flag>-a</flag>
        <flag>-r</flag>
        <flag>-v</flag>
        <flag>-vv</flag>
        <flag>--list</flag>
        <flag>--all</flag>
        <flag>--remotes</flag>
        <flag>--verbose</flag>
      </allowedFlags>
    </subcmd>
    <subcmd name="tag">
      <allowedFlags>
        <flag>-l</flag>
        <flag>-n</flag>
        <flag>--list</flag>
        <flag>--sort</flag>
      </allowedFlags>
    </subcmd>
    <subcmd name="remote">
      <allowedFlags>
        <flag>-v</flag>
        <flag>--verbose</flag>
      </allowedFlags>
      <subcmd name="show" allowedFlags="*"/>
      <subcmd name="get-url" allowedFlags="*"/>
    </subcmd>
    <subcmd name="submodule">
      <subcmd name="status" allowedFlags="*"/>
    </subcmd>
    <subcmd name="config">
      <requiredFlags>
        <flag>--get</flag>
        <flag>--list</flag>
        <flag>--get-all</flag>
        <flag>--get-regexp</flag>
        <flag>--get-urlmatch</flag>
        <flag>--get-color</flag>
        <flag>--get-colorbool</flag>
        <flag>-l</flag>
      </requiredFlags>
    </subcmd>
    <subcmd name="replace">
      <requiredFlags>
        <flag>-l</flag>
        <flag>--list</flag>
      </requiredFlags>
    </subcmd>
    <subcmd name="commit-graph">
      <subcmd name="verify" allowedFlags="*"/>
    </subcmd>
    <subcmd name="push">
      <requiredFlags>
        <flag>--dry-run</flag>
        <flag>-n</flag>
      </requiredFlags>
    </subcmd>
  </cmd>

  <!-- gh (GitHub CLI) -->
  <cmd name="gh">
    <subcmd name="repo">
      <subcmd name="view" allowedFlags="*"/>
      <subcmd name="list" allowedFlags="*"/>
    </subcmd>
    <subcmd name="issue">
      <subcmd name="list" allowedFlags="*"/>
      <subcmd name="view" allowedFlags="*"/>
      <subcmd name="status" allowedFlags="*"/>
    </subcmd>
    <subcmd name="pr">
      <subcmd name="list" allowedFlags="*"/>
      <subcmd name="view" allowedFlags="*"/>
      <subcmd name="status" allowedFlags="*"/>
      <subcmd name="diff" allowedFlags="*"/>
      <subcmd name="checks" allowedFlags="*"/>
    </subcmd>
    <subcmd name="release">
      <subcmd name="list" allowedFlags="*"/>
      <subcmd name="view" allowedFlags="*"/>
    </subcmd>
    <subcmd name="workflow">
      <subcmd name="list" allowedFlags="*"/>
      <subcmd name="view" allowedFlags="*"/>
    </subcmd>
    <subcmd name="run">
      <subcmd name="list" allowedFlags="*"/>
      <subcmd name="view" denyWithMessage="Use 'gh wait-ci' instead for checking CI status"/>
      <subcmd name="watch" denyWithMessage="Use 'gh wait-ci' instead for checking CI status"/>
    </subcmd>
    <subcmd name="search">
      <subcmd name="repos" allowedFlags="*"/>
      <subcmd name="issues" allowedFlags="*"/>
      <subcmd name="prs" allowedFlags="*"/>
      <subcmd name="commits" allowedFlags="*"/>
      <subcmd name="code" allowedFlags="*"/>
    </subcmd>
    <subcmd name="browse" allowedFlags="*"/>
    <subcmd name="label">
      <subcmd name="list" allowedFlags="*"/>
    </subcmd>
    <subcmd name="cache">
      <subcmd name="list" allowedFlags="*"/>
    </subcmd>
    <subcmd name="gist">
      <subcmd name="list" allowedFlags="*"/>
      <subcmd name="view" allowedFlags="*"/>
    </subcmd>
    <subcmd name="api">
      <requireFlagValue default="GET">
        <flag>-X</flag>
        <flag>--method</flag>
        <allowed>GET</allowed>
      </requireFlagValue>
    </subcmd>
  </cmd>

  <!-- claude CLI -->
  <cmd name="claude" helpAlwaysAllowed="true">
    <allowedFlags>
      <flag>--version</flag>
      <flag>-v</flag>
      <flag>--help</flag>
      <flag>-h</flag>
    </allowedFlags>
    <subcmd name="mcp">
      <allowedFlags>
        <flag>--help</flag>
        <flag>-h</flag>
      </allowedFlags>
      <subcmd name="list" allowedFlags="*"/>
      <subcmd name="get" allowedFlags="*"/>
    </subcmd>
    <subcmd name="plugin">
      <allowedFlags>
        <flag>--help</flag>
        <flag>-h</flag>
      </allowedFlags>
      <subcmd name="list" allowedFlags="*"/>
      <subcmd name="marketplace">
        <subcmd name="list" allowedFlags="*"/>
      </subcmd>
    </subcmd>
    <subcmd name="config">
      <allowedFlags>
        <flag>--help</flag>
        <flag>-h</flag>
      </allowedFlags>
      <subcmd name="list" allowedFlags="*"/>
      <subcmd name="get" allowedFlags="*"/>
    </subcmd>
  </cmd>

  <!-- just -->
  <cmd name="just">
    <requiredFlags>
      <flag>--list</flag>
      <flag>-l</flag>
      <flag>--summary</flag>
      <flag>--dump</flag>
      <flag>--evaluate</flag>
      <flag>--help</flag>
      <flag>-h</flag>
    </requiredFlags>
  </cmd>

  <!-- docker compose run --rm -->
  <cmd name="docker" description="docker compose run --rm">
    <subcmd name="compose">
      <flagsWithValue>
        <flag>-f</flag>
        <flag>--file</flag>
        <flag>-p</flag>
        <flag>--project-name</flag>
        <flag>--env-file</flag>
        <flag>--profile</flag>
        <flag>--progress</flag>
        <flag>--ansi</flag>
      </flagsWithValue>
      <subcmd name="run">
        <requiredFlags>
          <flag>--rm</flag>
        </requiredFlags>
      </subcmd>
    </subcmd>
  </cmd>

  <!-- docker-compose run --rm -->
  <cmd name="docker-compose" description="docker-compose run --rm">
    <flagsWithValue>
      <flag>-f</flag>
      <flag>--file</flag>
      <flag>-p</flag>
      <flag>--project-name</flag>
      <flag>--env-file</flag>
      <flag>--profile</flag>
      <flag>--progress</flag>
      <flag>--ansi</flag>
    </flagsWithValue>
    <subcmd name="run">
      <requiredFlags>
        <flag>--rm</flag>
      </requiredFlags>
    </subcmd>
  </cmd>

  <!-- docker-compose readonly -->
  <cmd name="docker-compose" description="readonly docker-compose">
    <flagsWithValue>
      <flag>-f</flag>
      <flag>--file</flag>
      <flag>-p</flag>
      <flag>--project-name</flag>
      <flag>--env-file</flag>
      <flag>--profile</flag>
      <flag>--progress</flag>
      <flag>--ansi</flag>
    </flagsWithValue>
    <subcmd name="ls" allowedFlags="*"/>
    <subcmd name="ps" allowedFlags="*"/>
    <subcmd name="top" allowedFlags="*"/>
    <subcmd name="images" allowedFlags="*"/>
    <subcmd name="logs" allowedFlags="*"/>
    <subcmd name="config" allowedFlags="*"/>
    <subcmd name="version" allowedFlags="*"/>
  </cmd>

  <!-- zpool -->
  <cmd name="zpool">
    <subcmd name="list" allowedFlags="*"/>
    <subcmd name="status" allowedFlags="*"/>
    <subcmd name="history" allowedFlags="*"/>
    <subcmd name="get" allowedFlags="*"/>
    <subcmd name="iostat" allowedFlags="*"/>
    <subcmd name="events" allowedFlags="*"/>
  </cmd>

  <!-- zfs -->
  <cmd name="zfs">
    <subcmd name="list" allowedFlags="*"/>
    <subcmd name="get" allowedFlags="*"/>
    <subcmd name="diff" allowedFlags="*"/>
    <subcmd name="holds" allowedFlags="*"/>
  </cmd>

  <!-- docker readonly -->
  <cmd name="docker" description="readonly docker">
    <subcmd name="inspect" allowedFlags="*"/>
    <subcmd name="ps" allowedFlags="*"/>
    <subcmd name="images" allowedFlags="*"/>
    <subcmd name="logs" allowedFlags="*"/>
    <subcmd name="version" allowedFlags="*"/>
    <subcmd name="info" allowedFlags="*"/>
    <subcmd name="top" allowedFlags="*"/>
    <subcmd name="port" allowedFlags="*"/>
    <subcmd name="diff" allowedFlags="*"/>
    <subcmd name="history" allowedFlags="*"/>
    <subcmd name="stats" allowedFlags="*"/>
    <subcmd name="events" allowedFlags="*"/>
    <subcmd name="search" allowedFlags="*"/>
    <subcmd name="image">
      <subcmd name="ls" allowedFlags="*"/>
      <subcmd name="list" allowedFlags="*"/>
      <subcmd name="inspect" allowedFlags="*"/>
      <subcmd name="history" allowedFlags="*"/>
    </subcmd>
    <subcmd name="container">
      <subcmd name="ls" allowedFlags="*"/>
      <subcmd name="list" allowedFlags="*"/>
      <subcmd name="inspect" allowedFlags="*"/>
      <subcmd name="logs" allowedFlags="*"/>
      <subcmd name="top" allowedFlags="*"/>
      <subcmd name="stats" allowedFlags="*"/>
      <subcmd name="port" allowedFlags="*"/>
      <subcmd name="diff" allowedFlags="*"/>
    </subcmd>
    <subcmd name="network">
      <subcmd name="ls" allowedFlags="*"/>
      <subcmd name="list" allowedFlags="*"/>
      <subcmd name="inspect" allowedFlags="*"/>
    </subcmd>
    <subcmd name="volume">
      <subcmd name="ls" allowedFlags="*"/>
      <subcmd name="list" allowedFlags="*"/>
      <subcmd name="inspect" allowedFlags="*"/>
    </subcmd>
    <subcmd name="context">
      <subcmd name="ls" allowedFlags="*"/>
      <subcmd name="list" allowedFlags="*"/>
      <subcmd name="show" allowedFlags="*"/>
      <subcmd name="inspect" allowedFlags="*"/>
    </subcmd>
    <subcmd name="config">
      <subcmd name="ls" allowedFlags="*"/>
      <subcmd name="list" allowedFlags="*"/>
      <subcmd name="inspect" allowedFlags="*"/>
    </subcmd>
    <subcmd name="secret">
      <subcmd name="ls" allowedFlags="*"/>
      <subcmd name="list" allowedFlags="*"/>
      <subcmd name="inspect" allowedFlags="*"/>
    </subcmd>
    <subcmd name="service">
      <subcmd name="ls" allowedFlags="*"/>
      <subcmd name="list" allowedFlags="*"/>
      <subcmd name="inspect" allowedFlags="*"/>
      <subcmd name="logs" allowedFlags="*"/>
      <subcmd name="ps" allowedFlags="*"/>
    </subcmd>
    <subcmd name="node">
      <subcmd name="ls" allowedFlags="*"/>
      <subcmd name="list" allowedFlags="*"/>
      <subcmd name="inspect" allowedFlags="*"/>
      <subcmd name="ps" allowedFlags="*"/>
    </subcmd>
    <subcmd name="stack">
      <subcmd name="ls" allowedFlags="*"/>
      <subcmd name="list" allowedFlags="*"/>
      <subcmd name="ps" allowedFlags="*"/>
      <subcmd name="services" allowedFlags="*"/>
    </subcmd>
    <subcmd name="plugin">
      <subcmd name="ls" allowedFlags="*"/>
      <subcmd name="list" allowedFlags="*"/>
      <subcmd name="inspect" allowedFlags="*"/>
    </subcmd>
    <subcmd name="system">
      <subcmd name="info" allowedFlags="*"/>
      <subcmd name="df" allowedFlags="*"/>
      <subcmd name="events" allowedFlags="*"/>
    </subcmd>
    <subcmd name="manifest">
      <subcmd name="inspect" allowedFlags="*"/>
    </subcmd>
    <subcmd name="buildx">
      <subcmd name="ls" allowedFlags="*"/>
      <subcmd name="inspect" allowedFlags="*"/>
      <subcmd name="du" allowedFlags="*"/>
      <subcmd name="version" allowedFlags="*"/>
    </subcmd>
    <subcmd name="compose">
      <flagsWithValue>
        <flag>-f</flag>
        <flag>--file</flag>
        <flag>-p</flag>
        <flag>--project-name</flag>
        <flag>--env-file</flag>
        <flag>--profile</flag>
        <flag>--progress</flag>
        <flag>--ansi</flag>
      </flagsWithValue>
      <subcmd name="ls" allowedFlags="*"/>
      <subcmd name="ps" allowedFlags="*"/>
      <subcmd name="top" allowedFlags="*"/>
      <subcmd name="images" allowedFlags="*"/>
      <subcmd name="logs" allowedFlags="*"/>
      <subcmd name="config" allowedFlags="*"/>
      <subcmd name="version" allowedFlags="*"/>
    </subcmd>
  </cmd>

  <!-- brew -->
  <cmd name="brew">
    <subcmd name="list" allowedFlags="*"/>
    <subcmd name="ls" allowedFlags="*"/>
    <subcmd name="info" allowedFlags="*"/>
    <subcmd name="search" allowedFlags="*"/>
    <subcmd name="config" allowedFlags="*"/>
    <subcmd name="doctor" allowedFlags="*"/>
    <subcmd name="deps" allowedFlags="*"/>
    <subcmd name="uses" allowedFlags="*"/>
    <subcmd name="outdated" allowedFlags="*"/>
    <subcmd name="leaves" allowedFlags="*"/>
    <subcmd name="desc" allowedFlags="*"/>
    <subcmd name="cat" allowedFlags="*"/>
    <subcmd name="home" allowedFlags="*"/>
    <subcmd name="log" allowedFlags="*"/>
    <subcmd name="options" allowedFlags="*"/>
    <subcmd name="formula" allowedFlags="*"/>
    <subcmd name="--version" allowedFlags="*"/>
    <subcmd name="--prefix" allowedFlags="*"/>
    <subcmd name="--cellar" allowedFlags="*"/>
    <subcmd name="--repository" allowedFlags="*"/>
    <subcmd name="--cache" allowedFlags="*"/>
    <subcmd name="analytics" allowedFlags="*"/>
    <subcmd name="commands" allowedFlags="*"/>
    <subcmd name="which-formula" allowedFlags="*"/>
    <subcmd name="tap-info" allowedFlags="*"/>
    <subcmd name="style" allowedFlags="*"/>
    <subcmd name="shellenv" allowedFlags="*"/>
    <subcmd name="tap">
      <allowedFlags/>
    </subcmd>
  </cmd>
</rules>
