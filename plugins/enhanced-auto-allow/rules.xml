<?xml version="1.0" encoding="UTF-8"?>
<rules>
  <!-- Readonly inspection commands -->
  <command name="ls" allowedFlags="*"/>
  <command name="cat" allowedFlags="*"/>
  <command name="head" allowedFlags="*"/>
  <command name="tail" allowedFlags="*"/>
  <command name="file" allowedFlags="*"/>
  <command name="wc" allowedFlags="*"/>
  <command name="stat" allowedFlags="*"/>
  <command name="du" allowedFlags="*"/>
  <command name="df" allowedFlags="*"/>
  <command name="uname" allowedFlags="*"/>
  <command name="uptime" allowedFlags="*"/>
  <command name="sw_vers" allowedFlags="*"/>
  <command name="arch" allowedFlags="*"/>
  <command name="hostinfo" allowedFlags="*"/>
  <command name="vm_stat" allowedFlags="*"/>
  <command name="whoami" allowedFlags="*"/>
  <command name="id" allowedFlags="*"/>
  <command name="groups" allowedFlags="*"/>
  <command name="pgrep" allowedFlags="*"/>
  <command name="which" allowedFlags="*"/>
  <command name="whereis" allowedFlags="*"/>
  <command name="readlink" allowedFlags="*"/>
  <command name="basename" allowedFlags="*"/>
  <command name="dirname" allowedFlags="*"/>
  <command name="printenv" allowedFlags="*"/>
  <command name="shasum" allowedFlags="*"/>
  <command name="md5" allowedFlags="*"/>
  <command name="strings" allowedFlags="*"/>
  <command name="hexdump" allowedFlags="*"/>
  <command name="od" allowedFlags="*"/>
  <command name="mdfind" allowedFlags="*"/>
  <command name="mdls" allowedFlags="*"/>
  <command name="locate" allowedFlags="*"/>
  <command name="echo" allowedFlags="*"/>
  <command name="printf" allowedFlags="*"/>
  <command name="true" allowedFlags="*"/>
  <command name="false" allowedFlags="*"/>
  <command name="test" allowedFlags="*"/>
  <command name="[" allowedFlags="*"/>
  <command name="date" allowedFlags="*"/>
  <command name="hostname" allowedFlags="*"/>
  <command name="pwd" allowedFlags="*"/>
  <command name="env" allowedFlags="*"/>
  <command name="sort" allowedFlags="*"/>
  <command name="uniq" allowedFlags="*"/>
  <command name="tr" allowedFlags="*"/>
  <command name="cut" allowedFlags="*"/>
  <command name="diff" allowedFlags="*"/>
  <command name="comm" allowedFlags="*"/>
  <command name="join" allowedFlags="*"/>
  <command name="paste" allowedFlags="*"/>
  <command name="column" allowedFlags="*"/>
  <command name="expand" allowedFlags="*"/>
  <command name="unexpand" allowedFlags="*"/>
  <command name="fold" allowedFlags="*"/>
  <command name="fmt" allowedFlags="*"/>
  <command name="nl" allowedFlags="*"/>
  <command name="rev" allowedFlags="*"/>
  <command name="tac" allowedFlags="*"/>
  <command name="seq" allowedFlags="*"/>
  <command name="realpath" allowedFlags="*"/>
  <command name="cd" allowedFlags="*"/>
  <command name="pkg-config" allowedFlags="*"/>
  <command name="pkgconf" allowedFlags="*"/>
  <command name="pkg_config" allowedFlags="*"/>

  <!-- find -->
  <command name="find" allowedFlags="*">
    <deniedFlags>
      <flag>-delete</flag>
    </deniedFlags>
    <execFlags>
      <flag>-exec</flag>
      <flag>-execdir</flag>
      <flag>-ok</flag>
      <flag>-okdir</flag>
    </execFlags>
  </command>

  <!-- grep -->
  <command name="grep" allowedFlags="*"/>

  <!-- ldconfig -->
  <command name="ldconfig">
    <requiredFlags>
      <flag>-p</flag>
      <flag>--print-cache</flag>
      <flag>-v</flag>
    </requiredFlags>
  </command>

  <!-- go -->
  <command name="go">
    <subcommand name="version" allowedFlags="*"/>
    <subcommand name="env" allowedFlags="*"/>
    <subcommand name="doc" allowedFlags="*"/>
  </command>

  <!-- git -->
  <command name="git">
    <subcommand name="status" allowedFlags="*"/>
    <subcommand name="diff" allowedFlags="*"/>
    <subcommand name="log" allowedFlags="*"/>
    <subcommand name="show" allowedFlags="*"/>
    <subcommand name="fetch" allowedFlags="*"/>
    <subcommand name="ls-files" allowedFlags="*"/>
    <subcommand name="ls-tree" allowedFlags="*"/>
    <subcommand name="ls-remote" allowedFlags="*"/>
    <subcommand name="rev-parse" allowedFlags="*"/>
    <subcommand name="rev-list" allowedFlags="*"/>
    <subcommand name="describe" allowedFlags="*"/>
    <subcommand name="blame" allowedFlags="*"/>
    <subcommand name="shortlog" allowedFlags="*"/>
    <subcommand name="whatchanged" allowedFlags="*"/>
    <subcommand name="reflog" allowedFlags="*"/>
    <subcommand name="count-objects" allowedFlags="*"/>
    <subcommand name="fsck" allowedFlags="*"/>
    <subcommand name="verify-pack" allowedFlags="*"/>
    <subcommand name="cat-file" allowedFlags="*"/>
    <subcommand name="for-each-ref" allowedFlags="*"/>
    <subcommand name="name-rev" allowedFlags="*"/>
    <subcommand name="merge-base" allowedFlags="*"/>
    <subcommand name="branch">
      <allowedFlags>
        <flag>-a</flag>
        <flag>-r</flag>
        <flag>-v</flag>
        <flag>-vv</flag>
        <flag>--list</flag>
        <flag>--all</flag>
        <flag>--remotes</flag>
        <flag>--verbose</flag>
      </allowedFlags>
    </subcommand>
    <subcommand name="tag">
      <allowedFlags>
        <flag>-l</flag>
        <flag>-n</flag>
        <flag>--list</flag>
        <flag>--sort</flag>
      </allowedFlags>
    </subcommand>
    <subcommand name="remote">
      <allowedFlags>
        <flag>-v</flag>
        <flag>--verbose</flag>
      </allowedFlags>
      <subcommand name="show" allowedFlags="*"/>
      <subcommand name="get-url" allowedFlags="*"/>
    </subcommand>
    <subcommand name="submodule">
      <subcommand name="status" allowedFlags="*"/>
    </subcommand>
    <subcommand name="config">
      <requiredFlags>
        <flag>--get</flag>
        <flag>--list</flag>
        <flag>--get-all</flag>
        <flag>--get-regexp</flag>
        <flag>--get-urlmatch</flag>
        <flag>--get-color</flag>
        <flag>--get-colorbool</flag>
        <flag>-l</flag>
      </requiredFlags>
    </subcommand>
    <subcommand name="replace">
      <requiredFlags>
        <flag>-l</flag>
        <flag>--list</flag>
      </requiredFlags>
    </subcommand>
    <subcommand name="commit-graph">
      <subcommand name="verify" allowedFlags="*"/>
    </subcommand>
    <subcommand name="push">
      <requiredFlags>
        <flag>--dry-run</flag>
        <flag>-n</flag>
      </requiredFlags>
    </subcommand>
  </command>

  <!-- gh (GitHub CLI) -->
  <command name="gh">
    <subcommand name="repo">
      <subcommand name="view" allowedFlags="*"/>
      <subcommand name="list" allowedFlags="*"/>
    </subcommand>
    <subcommand name="issue">
      <subcommand name="list" allowedFlags="*"/>
      <subcommand name="view" allowedFlags="*"/>
      <subcommand name="status" allowedFlags="*"/>
    </subcommand>
    <subcommand name="pr">
      <subcommand name="list" allowedFlags="*"/>
      <subcommand name="view" allowedFlags="*"/>
      <subcommand name="status" allowedFlags="*"/>
      <subcommand name="diff" allowedFlags="*"/>
      <subcommand name="checks" allowedFlags="*"/>
    </subcommand>
    <subcommand name="release">
      <subcommand name="list" allowedFlags="*"/>
      <subcommand name="view" allowedFlags="*"/>
    </subcommand>
    <subcommand name="workflow">
      <subcommand name="list" allowedFlags="*"/>
      <subcommand name="view" allowedFlags="*"/>
    </subcommand>
    <subcommand name="run">
      <subcommand name="list" allowedFlags="*"/>
      <subcommand name="view" denyWithMessage="Use 'gh wait-ci' instead for checking CI status"/>
      <subcommand name="watch" denyWithMessage="Use 'gh wait-ci' instead for checking CI status"/>
    </subcommand>
    <subcommand name="search">
      <subcommand name="repos" allowedFlags="*"/>
      <subcommand name="issues" allowedFlags="*"/>
      <subcommand name="prs" allowedFlags="*"/>
      <subcommand name="commits" allowedFlags="*"/>
      <subcommand name="code" allowedFlags="*"/>
    </subcommand>
    <subcommand name="browse" allowedFlags="*"/>
    <subcommand name="label">
      <subcommand name="list" allowedFlags="*"/>
    </subcommand>
    <subcommand name="cache">
      <subcommand name="list" allowedFlags="*"/>
    </subcommand>
    <subcommand name="gist">
      <subcommand name="list" allowedFlags="*"/>
      <subcommand name="view" allowedFlags="*"/>
    </subcommand>
    <subcommand name="api">
      <requireFlagValue default="GET">
        <flag>-X</flag>
        <flag>--method</flag>
        <allowed>GET</allowed>
      </requireFlagValue>
    </subcommand>
  </command>

  <!-- claude CLI -->
  <command name="claude" helpAlwaysAllowed="true">
    <allowedFlags>
      <flag>--version</flag>
      <flag>-v</flag>
      <flag>--help</flag>
      <flag>-h</flag>
    </allowedFlags>
    <subcommand name="mcp">
      <allowedFlags>
        <flag>--help</flag>
        <flag>-h</flag>
      </allowedFlags>
      <subcommand name="list" allowedFlags="*"/>
      <subcommand name="get" allowedFlags="*"/>
    </subcommand>
    <subcommand name="plugin">
      <allowedFlags>
        <flag>--help</flag>
        <flag>-h</flag>
      </allowedFlags>
      <subcommand name="list" allowedFlags="*"/>
      <subcommand name="marketplace">
        <subcommand name="list" allowedFlags="*"/>
      </subcommand>
    </subcommand>
    <subcommand name="config">
      <allowedFlags>
        <flag>--help</flag>
        <flag>-h</flag>
      </allowedFlags>
      <subcommand name="list" allowedFlags="*"/>
      <subcommand name="get" allowedFlags="*"/>
    </subcommand>
  </command>

  <!-- just -->
  <command name="just">
    <requiredFlags>
      <flag>--list</flag>
      <flag>-l</flag>
      <flag>--summary</flag>
      <flag>--dump</flag>
      <flag>--evaluate</flag>
      <flag>--help</flag>
      <flag>-h</flag>
    </requiredFlags>
  </command>

  <!-- docker compose run --rm -->
  <command name="docker" description="docker compose run --rm">
    <subcommand name="compose">
      <flagsWithValue>
        <flag>-f</flag>
        <flag>--file</flag>
        <flag>-p</flag>
        <flag>--project-name</flag>
        <flag>--env-file</flag>
        <flag>--profile</flag>
        <flag>--progress</flag>
        <flag>--ansi</flag>
      </flagsWithValue>
      <subcommand name="run">
        <requiredFlags>
          <flag>--rm</flag>
        </requiredFlags>
      </subcommand>
    </subcommand>
  </command>

  <!-- docker-compose run --rm -->
  <command name="docker-compose" description="docker-compose run --rm">
    <flagsWithValue>
      <flag>-f</flag>
      <flag>--file</flag>
      <flag>-p</flag>
      <flag>--project-name</flag>
      <flag>--env-file</flag>
      <flag>--profile</flag>
      <flag>--progress</flag>
      <flag>--ansi</flag>
    </flagsWithValue>
    <subcommand name="run">
      <requiredFlags>
        <flag>--rm</flag>
      </requiredFlags>
    </subcommand>
  </command>

  <!-- docker-compose readonly -->
  <command name="docker-compose" description="readonly docker-compose">
    <flagsWithValue>
      <flag>-f</flag>
      <flag>--file</flag>
      <flag>-p</flag>
      <flag>--project-name</flag>
      <flag>--env-file</flag>
      <flag>--profile</flag>
      <flag>--progress</flag>
      <flag>--ansi</flag>
    </flagsWithValue>
    <subcommand name="ls" allowedFlags="*"/>
    <subcommand name="ps" allowedFlags="*"/>
    <subcommand name="top" allowedFlags="*"/>
    <subcommand name="images" allowedFlags="*"/>
    <subcommand name="logs" allowedFlags="*"/>
    <subcommand name="config" allowedFlags="*"/>
    <subcommand name="version" allowedFlags="*"/>
  </command>

  <!-- zpool -->
  <command name="zpool">
    <subcommand name="list" allowedFlags="*"/>
    <subcommand name="status" allowedFlags="*"/>
    <subcommand name="history" allowedFlags="*"/>
    <subcommand name="get" allowedFlags="*"/>
    <subcommand name="iostat" allowedFlags="*"/>
    <subcommand name="events" allowedFlags="*"/>
  </command>

  <!-- zfs -->
  <command name="zfs">
    <subcommand name="list" allowedFlags="*"/>
    <subcommand name="get" allowedFlags="*"/>
    <subcommand name="diff" allowedFlags="*"/>
    <subcommand name="holds" allowedFlags="*"/>
  </command>

  <!-- docker readonly -->
  <command name="docker" description="readonly docker">
    <subcommand name="inspect" allowedFlags="*"/>
    <subcommand name="ps" allowedFlags="*"/>
    <subcommand name="images" allowedFlags="*"/>
    <subcommand name="logs" allowedFlags="*"/>
    <subcommand name="version" allowedFlags="*"/>
    <subcommand name="info" allowedFlags="*"/>
    <subcommand name="top" allowedFlags="*"/>
    <subcommand name="port" allowedFlags="*"/>
    <subcommand name="diff" allowedFlags="*"/>
    <subcommand name="history" allowedFlags="*"/>
    <subcommand name="stats" allowedFlags="*"/>
    <subcommand name="events" allowedFlags="*"/>
    <subcommand name="search" allowedFlags="*"/>
    <subcommand name="image">
      <subcommand name="ls" allowedFlags="*"/>
      <subcommand name="list" allowedFlags="*"/>
      <subcommand name="inspect" allowedFlags="*"/>
      <subcommand name="history" allowedFlags="*"/>
    </subcommand>
    <subcommand name="container">
      <subcommand name="ls" allowedFlags="*"/>
      <subcommand name="list" allowedFlags="*"/>
      <subcommand name="inspect" allowedFlags="*"/>
      <subcommand name="logs" allowedFlags="*"/>
      <subcommand name="top" allowedFlags="*"/>
      <subcommand name="stats" allowedFlags="*"/>
      <subcommand name="port" allowedFlags="*"/>
      <subcommand name="diff" allowedFlags="*"/>
    </subcommand>
    <subcommand name="network">
      <subcommand name="ls" allowedFlags="*"/>
      <subcommand name="list" allowedFlags="*"/>
      <subcommand name="inspect" allowedFlags="*"/>
    </subcommand>
    <subcommand name="volume">
      <subcommand name="ls" allowedFlags="*"/>
      <subcommand name="list" allowedFlags="*"/>
      <subcommand name="inspect" allowedFlags="*"/>
    </subcommand>
    <subcommand name="context">
      <subcommand name="ls" allowedFlags="*"/>
      <subcommand name="list" allowedFlags="*"/>
      <subcommand name="show" allowedFlags="*"/>
      <subcommand name="inspect" allowedFlags="*"/>
    </subcommand>
    <subcommand name="config">
      <subcommand name="ls" allowedFlags="*"/>
      <subcommand name="list" allowedFlags="*"/>
      <subcommand name="inspect" allowedFlags="*"/>
    </subcommand>
    <subcommand name="secret">
      <subcommand name="ls" allowedFlags="*"/>
      <subcommand name="list" allowedFlags="*"/>
      <subcommand name="inspect" allowedFlags="*"/>
    </subcommand>
    <subcommand name="service">
      <subcommand name="ls" allowedFlags="*"/>
      <subcommand name="list" allowedFlags="*"/>
      <subcommand name="inspect" allowedFlags="*"/>
      <subcommand name="logs" allowedFlags="*"/>
      <subcommand name="ps" allowedFlags="*"/>
    </subcommand>
    <subcommand name="node">
      <subcommand name="ls" allowedFlags="*"/>
      <subcommand name="list" allowedFlags="*"/>
      <subcommand name="inspect" allowedFlags="*"/>
      <subcommand name="ps" allowedFlags="*"/>
    </subcommand>
    <subcommand name="stack">
      <subcommand name="ls" allowedFlags="*"/>
      <subcommand name="list" allowedFlags="*"/>
      <subcommand name="ps" allowedFlags="*"/>
      <subcommand name="services" allowedFlags="*"/>
    </subcommand>
    <subcommand name="plugin">
      <subcommand name="ls" allowedFlags="*"/>
      <subcommand name="list" allowedFlags="*"/>
      <subcommand name="inspect" allowedFlags="*"/>
    </subcommand>
    <subcommand name="system">
      <subcommand name="info" allowedFlags="*"/>
      <subcommand name="df" allowedFlags="*"/>
      <subcommand name="events" allowedFlags="*"/>
    </subcommand>
    <subcommand name="manifest">
      <subcommand name="inspect" allowedFlags="*"/>
    </subcommand>
    <subcommand name="buildx">
      <subcommand name="ls" allowedFlags="*"/>
      <subcommand name="inspect" allowedFlags="*"/>
      <subcommand name="du" allowedFlags="*"/>
      <subcommand name="version" allowedFlags="*"/>
    </subcommand>
    <subcommand name="compose">
      <flagsWithValue>
        <flag>-f</flag>
        <flag>--file</flag>
        <flag>-p</flag>
        <flag>--project-name</flag>
        <flag>--env-file</flag>
        <flag>--profile</flag>
        <flag>--progress</flag>
        <flag>--ansi</flag>
      </flagsWithValue>
      <subcommand name="ls" allowedFlags="*"/>
      <subcommand name="ps" allowedFlags="*"/>
      <subcommand name="top" allowedFlags="*"/>
      <subcommand name="images" allowedFlags="*"/>
      <subcommand name="logs" allowedFlags="*"/>
      <subcommand name="config" allowedFlags="*"/>
      <subcommand name="version" allowedFlags="*"/>
    </subcommand>
  </command>

  <!-- brew -->
  <command name="brew">
    <subcommand name="list" allowedFlags="*"/>
    <subcommand name="ls" allowedFlags="*"/>
    <subcommand name="info" allowedFlags="*"/>
    <subcommand name="search" allowedFlags="*"/>
    <subcommand name="config" allowedFlags="*"/>
    <subcommand name="doctor" allowedFlags="*"/>
    <subcommand name="deps" allowedFlags="*"/>
    <subcommand name="uses" allowedFlags="*"/>
    <subcommand name="outdated" allowedFlags="*"/>
    <subcommand name="leaves" allowedFlags="*"/>
    <subcommand name="desc" allowedFlags="*"/>
    <subcommand name="cat" allowedFlags="*"/>
    <subcommand name="home" allowedFlags="*"/>
    <subcommand name="log" allowedFlags="*"/>
    <subcommand name="options" allowedFlags="*"/>
    <subcommand name="formula" allowedFlags="*"/>
    <subcommand name="--version" allowedFlags="*"/>
    <subcommand name="--prefix" allowedFlags="*"/>
    <subcommand name="--cellar" allowedFlags="*"/>
    <subcommand name="--repository" allowedFlags="*"/>
    <subcommand name="--cache" allowedFlags="*"/>
    <subcommand name="analytics" allowedFlags="*"/>
    <subcommand name="commands" allowedFlags="*"/>
    <subcommand name="which-formula" allowedFlags="*"/>
    <subcommand name="tap-info" allowedFlags="*"/>
    <subcommand name="style" allowedFlags="*"/>
    <subcommand name="shellenv" allowedFlags="*"/>
    <subcommand name="tap">
      <allowedFlags/>
    </subcommand>
  </command>
</rules>
