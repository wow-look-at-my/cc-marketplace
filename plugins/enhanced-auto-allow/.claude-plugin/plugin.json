{
	"$schema": "../../example-plugin/.claude-plugin/plugin.schema.json",
	"name": "enhanced-auto-allow",
	"description": "Auto-approve readonly git and gh commands using JSON-driven rules",
	"author": {
		"name": "mhaynie"
	},
	"keywords": ["git", "github", "auto-allow", "permissions"],
	"hooks": {
		"PermissionRequest": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/run"
					}
				]
			},
			{
				"matcher": "Read|Glob|Grep",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/run"
					}
				]
			}
		]
	},
	"mh": {
		"include_in_marketplace": true
	}
}
