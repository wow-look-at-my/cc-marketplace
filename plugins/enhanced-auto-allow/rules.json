{
	"testcases": [
		"git status",
		"git diff",
		"git log --oneline -10",
		"git status 2>&1",
		"git remote -v",
		"git remote show origin",
		{"match": "git branch", "tests": {"git branch -a": "allow", "git branch -d feature": ""}},
		{"match": "git config", "tests": {
			"git config --get user.email": "allow",
			"git config --list": "allow",
			"git config --local --list 2>&1": "allow",
			"git config --get-urlmatch http https://example.com": "allow",
			"git config user.email foo@bar.com": ""
		}},
		{"match": "git replace", "tests": {"git replace -l 2>&1": "allow", "git replace --list": "allow", "git replace abc123 def456": ""}},
		{"match": "git commit-graph", "tests": {"git commit-graph verify": "allow", "git commit-graph write": ""}},
		{"match": "git push", "tests": {"git push --dry-run origin main": "allow", "git push -n origin main": "allow", "git push origin main": ""}},
		{"match": "git submodule", "tests": {"git submodule status": "allow", "git submodule status --recursive": "allow", "git submodule update --init": ""}},

		{"match": "gh pr", "tests": {"gh pr list": "allow", "gh pr view 123": "allow", "gh pr create": ""}},
		{"match": "gh api", "tests": {"gh api /repos/owner/repo": "allow", "gh api -X POST /repos/owner/repo": ""}},
		"gh repo view wow-look-at-my/go-toolchain",
		"gh repo view wow-look-at-my/go-toolchain --json name,description",
		"gh repo list",
		"gh release list",
		"gh release list -R owner/repo",
		"gh release view v1.0.0",
		"gh browse",
		{"match": "gh run", "tests": {"gh run list": "allow", "gh run view 123": "deny", "gh run watch 123": "deny"}},

		{"match": "find", "tests": {
			"find . -name '*.go' -type f": "allow",
			"find /home/mhaynie -type f -name \"*decode*\" -o -name \"*parse*\" 2>/dev/null | grep -i tool": "allow",
			"find /home/mhaynie/repos/UnrealEngine -name \"*.h\" -type f -exec grep -l \"class FSkeletalMeshSceneProxy\" {} \\;": "allow",
			"find . -name '*.tmp' -exec rm {} \\;": "",
			"find . -name '*.tmp' -delete": ""
		}},

		"pkg-config --cflags openssl",
		"pkg-config --libs openssl",
		"pkg-config --modversion openssl",
		"pkg-config --list-all",
		"pkg-config --exists libcurl",
		"pkgconf --cflags openssl",
		"pkg_config --libs openssl",

		{"match": "ldconfig", "tests": {"ldconfig -p": "allow", "ldconfig --print-cache": "allow", "ldconfig": ""}},
		{"match": "go", "tests": {
			"go version": "allow",
			"go env GOPATH": "allow",
			"go doc fmt": "allow",
			"go doc fmt.Println": "allow",
			"go doc -all fmt": "allow",
			"go build ./...": ""
		}},

		"which node",
		"which git node python",
		"grep -ri 'TODO' src/",
		"echo hello | grep hello",
		"git log | head",
		"git show 54d7aa918a94 --stat && echo \"---\" && git show 54d7aa918a94 -- path/to/file.cpp",

		{"match": "passthrough", "tests": {
			"git log $(echo test)": "",
			"git log | python": "",
			"python --version": "",
			"echo foo > file.txt": "",
			"echo foo >> file.txt": "",
			"sort input.txt > output.txt": ""
		}},

		{"match": "safe redirects", "tests": {
			"ls > /tmp/out.txt": "allow",
			"ls >> /tmp/out.txt": "allow",
			"ls > /dev/null": "allow",
			"ls > /tmp/sub/out.txt": "allow",
			"ls 2> /tmp/err.txt": "allow",
			"ls &> /tmp/out.txt": "allow",
			"ls &>> /tmp/out.txt": "allow",
			"ls > /etc/foo.txt": "",
			"ls > out.txt": "",
			"ls > /tmp/../etc/passwd": "",
			"gh api --hostname github.com -H \"Accept: application/vnd.github.raw+json\" \"repos/hagezi/dns-blocklists/contents/wildcard/pro.mini-onlydomains.txt\" 2>/dev/null > /tmp/hagezi.txt && wc -l /tmp/hagezi.txt": "allow"
		}},

		{"match": "just", "tests": {
			"just --list": "allow",
			"just --list 2>/dev/null || echo \"no justfile\"": "allow",
			"just build": ""
		}},
		{"match": "claude", "tests": {
			"claude mcp list": "allow",
			"claude mcp --help": "allow",
			"claude mcp get server-name": "allow",
			"claude mcp add my-server -- npx server": "",
			"claude mcp remove my-server": "",
			"claude --version": "allow",
			"claude --help": "allow",
			"claude plugin list": "allow",
			"claude plugin marketplace list": "allow",
			"claude plugin install some-plugin": "",
			"claude config list": "allow",
			"claude config get key": "allow",
			"claude config set key value": "",
			"claude plugin --help": "allow",
			"claude hook --help": "allow",
			"claude plugin marketplace add --help": "allow",
			"claude whatever -h": "allow",
			"claude hook list": ""
		}},

		{"match": "docker compose run", "tests": {
			"docker compose run --rm myservice": "allow",
			"docker compose run --rm myservice bash": "allow",
			"docker compose -f docker-compose.yml run --rm myservice": "allow",
			"docker compose --file docker-compose.yml run --rm myservice": "allow",
			"docker compose -f compose.yml -p myproject run --rm myservice": "allow",
			"docker compose -f compose.yml run myservice --rm": "allow",
			"docker-compose run --rm myservice": "allow",
			"docker-compose -f docker-compose.yml run --rm myservice": "allow",
			"docker compose run myservice": "",
			"docker-compose run myservice": "",
			"docker compose up": "",
			"docker compose down": ""
		}},
		{"match": "docker compose ps", "tests": {
			"docker compose ps": "allow",
			"docker compose ps --all": "allow",
			"docker compose -f docker-compose.yml ps": "allow",
			"docker-compose ps": "allow"
		}},

		{"match": "mount", "tests": {"mount": "allow", "mount /dev/sda1 /mnt": "", "mount -t ext4 /dev/sda1 /mnt": ""}},

		{"match": "compound commands", "tests": {
			"git status && git diff": "allow",
			"git status && python --version": "",
			"git status || git diff": "allow",
			"git fetch origin latest && git show HEAD": "allow",
			"ls && cat file.txt": "allow",
			"git status && gh run view 123": "deny",
			"git status && git diff && git log": "allow",
			"git status; git diff": "allow",
			"cd some/folder && git diff Config/DefaultEngine.ini": "allow"
		}}
	],
