{
	"$schema": "../../example-plugin/.claude-plugin/plugin.schema.json",
	"name": "haiku-compact",
	"description": "Switches the active model to Haiku during context compaction and restores it afterwards",
	"author": {
		"name": "mhaynie"
	},
	"keywords": ["compact", "haiku", "model", "cost", "hook"],
	"hooks": {
		"PreCompact": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bash ${CLAUDE_PLUGIN_ROOT}/hook.sh"
					}
				]
			}
		],
		"PostCompact": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bash ${CLAUDE_PLUGIN_ROOT}/hook.sh"
					}
				]
			}
		]
	},
	"mh": {
		"include_in_marketplace": true
	}
}
