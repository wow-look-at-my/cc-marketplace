{
	"author": {
		"name": "mhaynie"
	},
	"description": "Rewrites Bash commands to remove unnecessary 2\u003e\u00261, || true, | head, | tail, and set -e",
	"hooks": {
		"PreToolUse": [
			{
				"hooks": [
					{
						"command": "${CLAUDE_PLUGIN_ROOT}/build/cleanup-bash-cmds",
						"type": "command"
					}
				],
				"matcher": "Bash"
			}
		]
	},
	"keywords": [
		"bash",
		"cleanup",
		"rewrite",
		"hook"
	],
	"name": "cleanup-bash-cmds",
	"version": "2"
}