{
  "metadata": {
    "description": "Claude Code plugins by wow-look-at-my-code",
    "pluginRoot": "./plugins",
    "version": "12"
  },
  "name": "wow-cc-marketplace",
  "owner": {
    "name": "wow-look-at-my-code"
  },
  "plugins": [
    {
      "author": {
        "name": "wow-look-at-my-code"
      },
      "description": "MCP server for crawling web pages using crawl4ai and returning content as markdown",
      "keywords": [
        "web-crawling",
        "scraping",
        "markdown",
        "mcp"
      ],
      "mcpServers": "./.mcp.json",
      "name": "crawl4ai",
      "source": {
        "ref": "plugin/crawl4ai/v6",
        "repo": "wow-look-at-my-code/cc-marketplace",
        "source": "github"
      },
      "version": "6"
    },
    {
      "author": {
        "name": "mhaynie"
      },
      "description": "Auto-approve readonly git and gh commands using JSON-driven rules",
      "hooks": {
        "PermissionRequest": [
          {
            "hooks": [
              {
                "command": "${CLAUDE_PLUGIN_ROOT}/run",
                "type": "command"
              }
            ],
            "matcher": "Bash"
          },
          {
            "hooks": [
              {
                "command": "${CLAUDE_PLUGIN_ROOT}/run",
                "type": "command"
              }
            ],
            "matcher": "Read|Glob|Grep"
          }
        ]
      },
      "keywords": [
        "git",
        "github",
        "auto-allow",
        "permissions"
      ],
      "name": "enhanced-auto-allow",
      "source": {
        "ref": "plugin/enhanced-auto-allow/v10",
        "repo": "wow-look-at-my-code/cc-marketplace",
        "source": "github"
      },
      "version": "10"
    },
    {
      "author": {
        "name": "mhaynie"
      },
      "description": "Fetch text content from URLs referenced with @https://... in prompts",
      "hooks": {
        "UserPromptSubmit": [
          {
            "hooks": [
              {
                "command": "${CLAUDE_PLUGIN_ROOT}/hook",
                "type": "command"
              }
            ]
          }
        ]
      },
      "keywords": [
        "fetch",
        "url",
        "text",
        "content"
      ],
      "name": "prompt-url-fetch",
      "source": {
        "ref": "plugin/prompt-url-fetch/v4",
        "repo": "wow-look-at-my-code/cc-marketplace",
        "source": "github"
      },
      "version": "4"
    }
  ]
}