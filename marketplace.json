{
  "metadata": {
    "description": "Claude Code plugins by wow-look-at-my-code",
    "pluginRoot": "./plugins",
    "version": "1"
  },
  "name": "wow-cc-marketplace",
  "owner": {
    "name": "wow-look-at-my-code"
  },
  "plugins": [
    {
      "author": {
        "name": "wow-look-at-my-code"
      },
      "category": "development",
      "description": "MCP server wrapping jq for JSON filtering, querying, and transforming without Bash permission prompts",
      "keywords": [
        "jq",
        "json",
        "filter",
        "query",
        "mcp"
      ],
      "mcpServers": "./.mcp.json",
      "name": "jq",
      "source": {
        "ref": "plugin/jq#4",
        "repo": "wow-look-at-my/cc-marketplace",
        "source": "github"
      },
      "version": "3"
    },
    {
      "author": {
        "name": "mhaynie"
      },
      "description": "Blocks the Write tool from overwriting existing files - forces use of Edit instead",
      "hooks": {
        "PreToolUse": [
          {
            "hooks": [
              {
                "command": "${CLAUDE_PLUGIN_ROOT}/hook",
                "type": "command"
              }
            ],
            "matcher": "Write"
          }
        ]
      },
      "keywords": [
        "write",
        "edit",
        "overwrite",
        "guard",
        "hook"
      ],
      "name": "no-overwrites",
      "source": {
        "ref": "plugin/no-overwrites#4",
        "repo": "wow-look-at-my/cc-marketplace",
        "source": "github"
      },
      "version": "1"
    },
    {
      "author": {
        "name": "mhaynie"
      },
      "description": "Fetch text content from URLs referenced with @https://... in prompts",
      "hooks": {
        "UserPromptSubmit": [
          {
            "hooks": [
              {
                "command": "${CLAUDE_PLUGIN_ROOT}/hook",
                "type": "command"
              }
            ]
          }
        ]
      },
      "keywords": [
        "fetch",
        "url",
        "text",
        "content"
      ],
      "name": "prompt-url-fetch",
      "source": {
        "ref": "plugin/prompt-url-fetch#5",
        "repo": "wow-look-at-my/cc-marketplace",
        "source": "github"
      },
      "version": "3"
    },
    {
      "author": {
        "name": "mhaynie"
      },
      "description": "Blocks direct go build/test commands - use go-toolchain instead",
      "hooks": {
        "PreToolUse": [
          {
            "hooks": [
              {
                "command": "${CLAUDE_PLUGIN_ROOT}/hook",
                "type": "command"
              }
            ],
            "matcher": "Bash"
          }
        ]
      },
      "keywords": [
        "go",
        "build",
        "test",
        "toolchain",
        "hook"
      ],
      "name": "recommend-go-toolchain",
      "source": {
        "ref": "plugin/recommend-go-toolchain#1",
        "repo": "wow-look-at-my/cc-marketplace",
        "source": "github"
      },
      "version": "1"
    },
    {
      "author": {
        "name": "wow-look-at-my-code"
      },
      "category": "development",
      "description": "MCP server for Chrome DevTools Protocol - inspect, debug, and interact with Chrome browser pages",
      "keywords": [
        "chrome",
        "devtools",
        "browser",
        "debugging",
        "mcp"
      ],
      "mcpServers": "./.mcp.json",
      "name": "chrome-devtools",
      "source": {
        "ref": "plugin/chrome-devtools#6",
        "repo": "wow-look-at-my/cc-marketplace",
        "source": "github"
      },
      "version": "1"
    },
    {
      "author": {
        "name": "wow-look-at-my-code"
      },
      "description": "MCP server for crawling web pages using crawl4ai and returning content as markdown",
      "keywords": [
        "web-crawling",
        "scraping",
        "markdown",
        "mcp"
      ],
      "mcpServers": "./.mcp.json",
      "name": "crawl4ai",
      "source": {
        "ref": "plugin/crawl4ai#1",
        "repo": "wow-look-at-my/cc-marketplace",
        "source": "github"
      },
      "version": "5"
    },
    {
      "author": {
        "name": "mhaynie"
      },
      "description": "Auto-approve readonly git and gh commands using JSON-driven rules",
      "hooks": {
        "PermissionRequest": [
          {
            "hooks": [
              {
                "command": "${CLAUDE_PLUGIN_ROOT}/run",
                "type": "command"
              }
            ],
            "matcher": "Bash"
          },
          {
            "hooks": [
              {
                "command": "${CLAUDE_PLUGIN_ROOT}/run",
                "type": "command"
              }
            ],
            "matcher": "Read|Glob|Grep"
          }
        ]
      },
      "keywords": [
        "git",
        "github",
        "auto-allow",
        "permissions"
      ],
      "name": "enhanced-auto-allow",
      "source": {
        "ref": "plugin/enhanced-auto-allow#4",
        "repo": "wow-look-at-my/cc-marketplace",
        "source": "github"
      },
      "version": "25"
    },
    {
      "author": {
        "name": "wow-look-at-my-code"
      },
      "category": "development",
      "description": "Create organized, well-structured HTML demo pages with separate CSS and JS files",
      "keywords": [
        "html",
        "demo",
        "frontend",
        "prototype"
      ],
      "name": "html-demo",
      "source": {
        "ref": "plugin/html-demo#4",
        "repo": "wow-look-at-my/cc-marketplace",
        "source": "github"
      },
      "version": "6"
    }
  ]
}